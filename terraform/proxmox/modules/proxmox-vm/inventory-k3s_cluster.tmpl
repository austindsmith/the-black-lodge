all:
  children:
    k3s_cluster:
      children:
        server:
          hosts:
%{ for name, node in nodes ~}
            ${name}:
              ansible_host: ${split("/", node.ip)[0]}
%{ endfor ~}
        agent:
          hosts: {}
      vars:
        ansible_port: 22
        ansible_user: ansible
        k3s_version: v1.36.1+k3s1
        api_endpoint: "{{ hostvars[groups['server'][0]]['ansible_host'] | default(groups['server'][0]) }}"
        extra_server_args: >-
            --disable=traefik
            --disable=servicelb
            --kube-apiserver-arg=oidc-issuer-url=https://authentik.theblacklodge.dev/application/o/headlamp/
            --kube-apiserver-arg=oidc-client-id={{ oidc_client_id }}
            --kube-apiserver-arg=oidc-username-claim=email
            --kube-apiserver-arg=oidc-groups-claim=groups
            --kube-apiserver-arg=oidc-username-prefix=oidc:
            --kube-apiserver-arg=oidc-groups-prefix=oidc:
        cluster_context: k3s-ansible
